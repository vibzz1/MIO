)

col_a, col_b = st.columns(2)
with col_a:
    min_grade = st.select_slider("Min Grade:", ["C", "B", "A", "A+"], value="B")
with col_b:
    show_charts = st.checkbox("Show TV charts", value=True)

if st.button("🧠 Score Setups", type="primary"):

    raw = tickers_input.replace(",", " ").replace("\n", " ").split()
    tickers = [t.strip().upper() for t in raw if t.strip()]

    if not tickers:
        st.error("Paste at least 1 ticker.")
    else:
        st.info(f"Fetching data for {len(tickers)} stocks...")
        progress = st.progress(0, text="Fetching...")

        results = []
        with concurrent.futures.ThreadPoolExecutor(max_workers=15) as exe:
            futures = {exe.submit(fetch_stock_data, t): t for t in tickers}
            for i, future in enumerate(concurrent.futures.as_completed(futures)):
                res = future.result()
                if res:
                    results.append(res)
                progress.progress((i + 1) / len(tickers), text=f"Fetched {i+1}/{len(tickers)}")

        progress.empty()

        if not results:
            st.error("Could not fetch data for any ticker. Check symbols.")
        else:
            st.info(f"🧠 Scoring {len(results)} stocks...")
            scored = []
            for res in results:
                try:
                    scored.append(full_score(res))
                except Exception as e:
                    st.warning(f"Skipped {res['Ticker']}: {e}")

            grade_map = {"A+": 4, "A": 3, "B": 2, "C": 1}
            min_val = grade_map[min_grade]
            filtered = [s for s in scored if grade_map.get(s['Grade'], 0) >= min_val]
            filtered.sort(key=lambda x: x['Total'], reverse=True)

            if not filtered:
                st.warning(f"No stocks scored {min_grade}+. Showing all.")
                filtered = sorted(scored, key=lambda x: x['Total'], reverse=True)

            st.success(f"🏆 {len(filtered)} setups scored {min_grade}+")

            # ============================================================
            # SCORECARD TABLE
            # ============================================================
            st.subheader("📋 Ranked Scorecard")

            table_cols = [
                'Ticker', 'Industry', 'CMP', 'Grade', 'Total',
                'Base', 'Stage', 'Timing',
                'Entry', 'SL', 'Risk%',
                'Base Depth', 'ATR Contr', 'Tight Days',
                'MA Stack', '200DMA', 'Above 52WL', 'Below 52WH',
                'Dist 20DMA', 'Vol Ratio', 'Body%'
            ]
            df_table = pd.DataFrame([{k: v for k, v in s.items() if k in table_cols} for s in filtered])
            df_table.index = df_table.index + 1

            def color_grade(val):
                colors = {
                    "A+": "background-color:#26a69a;color:white;font-weight:bold",
                    "A": "background-color:#4ade80;color:black;font-weight:bold",
                    "B": "background-color:#fbbf24;color:black",
                    "C": "background-color:#ef5350;color:white"
                }
                return colors.get(val, "")

            def color_total(val):
                try:
                    v = int(val)
                    if v >= 75:
                        return "background-color:#26a69a;color:white"
                    elif v >= 60:
                        return "background-color:#4ade80;color:black"
                    elif v >= 45:
                        return "background-color:#fbbf24;color:black"
                    else:
                        return "background-color:#ef5350;color:white"
                except:
                    return ""

            styled = df_table.style.applymap(color_grade, subset=['Grade']).applymap(color_total, subset=['Total'])
            st.dataframe(styled, use_container_width=True, height=400)

            st.divider()

            # ============================================================
            # SCORE BREAKDOWN — HORIZONTAL BAR
            # ============================================================
            st.subheader("📊 Score Breakdown")

            for res in filtered[:15]:
                t = res['Ticker']
                total = res['Total']
                base = res['Base']
                stage = res['Stage']
                timing = res['Timing']
                grade = res['Grade']

                grade_emoji = {"A+": "🟢", "A": "🟡", "B": "🟠", "C": "🔴"}.get(grade, "⚪")

                # Visual bar using unicode blocks
                bar_base = "█" * (base // 2)
                bar_stage = "█" * (stage // 2)
                bar_timing = "█" * (timing // 2)

                st.markdown(
                    f"{grade_emoji} **{t}** ({grade} · {total}/100) — "
                    f"🧱 Base `{base}/33` · 📶 Stage `{stage}/33` · ⏱️ Timing `{timing}/34`"
                )

            st.divider()

            # ============================================================
            # TV-STYLE CHARTS
            # ============================================================
            if show_charts:
                st.subheader("📈 Daily Charts (TradingView Style)")

                for res in filtered[:10]:
                    ticker = res['Ticker']
                    grade = res['Grade']
                    total = res['Total']

                    col1, col2 = st.columns([4, 1])

                    with col1:
                        st.markdown(
                            f"### {grade} | **{ticker}** — {total}/100 | {res['Industry']}"
                        )
                        render_tv_chart(res['df'], ticker, grade, total)

                    with col2:
                        st.markdown("**Scores**")
                        for dim, mx, emoji in [('Base', 33, '🧱'), ('Stage', 33, '📶'), ('Timing', 34, '⏱️')]:
                            val = res[dim]
                            pct = val / mx
                            bars = int(pct * 10)
                            bar = "█" * bars + "░" * (10 - bars)
                            st.markdown(f"{emoji} **{dim}**: {val}/{mx}\n`{bar}`")

                        st.divider()
                        st.metric("Entry", f"₹{res['Entry']}")
                        st.metric("SL (Base Low)", f"₹{res['SL']}")
                        st.metric("Risk", f"{res['Risk%']}%")
                        st.markdown(f"**Dist 20DMA:** {res['Dist 20DMA']}")
                        st.markdown(f"**Vol Ratio:** {res['Vol Ratio']}")

                    st.markdown("---")

